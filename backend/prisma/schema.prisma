generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model transaction {
  id                Int                @id @default(autoincrement())
  amount            Int
  currency          String             @default("INR")
  status            transaction_status @default(PENDING)
  razorpayOrderId   String             @unique(map: "Transaction_razorpayOrderId_key")
  razorpayPaymentId String?            @unique(map: "Transaction_razorpayPaymentId_key")
  razorpaySignature String?            @unique(map: "Transaction_razorpaySignature_key")
  provider          String
  userId            Int
  reason            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              user               @relation(fields: [userId], references: [id], map: "Transaction_userId_fkey", onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "Transaction_userId_fkey")
}

model user {
  id          Int           @id @default(autoincrement())
  email       String        @unique(map: "User_email_key")
  name        String?
  password    String?
  isVerified  Boolean       @default(false)
  role        user_role     @default(USER)
  isActive    Boolean       @default(true)
  isDeleted   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  transaction transaction[]
  carts       cart[]
}

model product {
  product_id          Int            @id @default(autoincrement())
  product_name        String
  product_description String
  display_price       Float
  discount_price      Float
  product_quantity    Int
  product_stock       Int
  product_image       String
  product_status      product_status @default(AVAILABLE)
  deleted_at          DateTime?
  updated_at          DateTime       @updatedAt
  created_at          DateTime       @default(now())
  carts               cart[]
}

model cart {
  cart_id Int @id @default(autoincrement())

  fk_user_id    Int
  fk_product_id Int

  cart_quantity Int @default(1)
  cart_amount   Int

  is_cart_cleared Boolean @default(true)

  user user @relation(fields: [fk_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  product product @relation(fields: [fk_product_id], references: [product_id], onDelete: Cascade, onUpdate: Cascade)

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@unique([fk_user_id, fk_product_id])
  @@index([fk_user_id], map: "Cart_user_id_fk_fkey")
  @@index([fk_product_id], map: "Cart_product_id_fk_fkey")
}

enum transaction_status {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum product_status {
  AVAILABLE
  UNAVAILABLE
}

enum user_role {
  USER
  ADMIN
}
